generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ──────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  arguments     Argument[]
  questions     Question[]
  argVotes      ArgumentVote[]
  questionVotes QuestionVote[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ──────────────────────────────────

enum Tag {
  NEWS
  TECH
  EDUCATION
  POLITICS
  RELIGION
  GAMING
  SPORTS
  ENTERTAINMENT
}

enum ArgumentKind {
  ROOT
  SUPPORT
  COUNTER
  REPLY
}

model Argument {
  id       String       @id @default(cuid())
  content  String
  imageUrl String?
  kind       ArgumentKind @default(ROOT)
  tag        Tag?
  replyCount Int          @default(0)

  authorId String
  author   User @relation(fields: [authorId], references: [id])

  // Parent argument (for SUPPORT and COUNTER kinds)
  parentId String?
  parent   Argument?  @relation("ChildArguments", fields: [parentId], references: [id])
  children Argument[] @relation("ChildArguments")

  // Parent question (for REPLY kind)
  questionId String?
  question   Question? @relation("QuestionReplies", fields: [questionId], references: [id])

  // Questions asked about this argument
  questions Question[] @relation("ArgumentQuestions")

  votes ArgumentVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArgumentVote {
  id         String @id @default(cuid())
  value      Int // 1 = upvote, -1 = downvote

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  argumentId String
  argument   Argument @relation(fields: [argumentId], references: [id], onDelete: Cascade)

  @@unique([userId, argumentId])
}

model Question {
  id       String  @id @default(cuid())
  content  String
  imageUrl String?

  authorId String
  author   User @relation(fields: [authorId], references: [id])

  argumentId String
  argument   Argument @relation("ArgumentQuestions", fields: [argumentId], references: [id])

  replies Argument[] @relation("QuestionReplies")

  votes QuestionVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestionVote {
  id         String @id @default(cuid())
  value      Int // 1 = upvote, -1 = downvote

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}
