# ─── Database (Neon) ──────────────────────────────
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ─── Auth ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="https://your-app.vercel.app"

# Google OAuth: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://your-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Object Storage (Cloudflare R2) ───────────────
# R2 API endpoint: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="truth-seeker"
# R2 public URL: enable public access on the bucket, then use the dev URL
# e.g. https://pub-abc123.r2.dev
S3_PUBLIC_URL=""

# ─── Cleanup cron ─────────────────────────────────
CLEANUP_SECRET=""
